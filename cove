#!/bin/bash
set -e

# Resolve the directory containing this script (and the Dockerfile)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Image selection: COVE_IMAGE=gpu-amd → cove-gpu-amd, unset → cove
IMAGE_NAME="localhost/cove${COVE_IMAGE:+-$COVE_IMAGE}"

show_help() {
    cat <<'EOF'
Usage: cove <tool> [-e VAR[=val]...] [path] [args...]
       cove <command> [args...]

Run AI coding tools in an isolated container.

Tools:
    cove claude                    Claude Code in current directory
    cove codex                     Codex in current directory
    cove kimi                      Kimi Code in current directory
    cove claude ~/project          Claude Code in ~/project
    cove claude --resume           Pass extra args to tool
    cove shell                     Interactive shell
    cove claude -e MY_KEY=secret   Pass extra env vars

Variants (via COVE_IMAGE env var):
    COVE_IMAGE=gpu-amd cove claude   Use GPU-enabled image (AMD ROCm)
    export COVE_IMAGE=gpu-amd        Set once in shell profile

Management:
    cove build                     Build/rebuild the container image
    cove build gpu-amd             Build a specific variant
    cove upgrade                   Pull latest and rebuild all images
    cove test                      Smoke test the current image
    cove ps                        List running coves
    cove stop <name>               Stop a running cove
    cove exec <name>               Attach to a running cove

Auto-passed env vars (if set on host):
    ANTHROPIC_API_KEY, CLAUDE_CODE_OAUTH_TOKEN, CODEX_API_KEY,
    KIMI_API_KEY, OPENAI_API_KEY, OPENROUTER_API_KEY,
    GOOGLE_API_KEY, MISTRAL_API_KEY, MODAL_TOKEN_ID,
    MODAL_TOKEN_SECRET
EOF
    exit "${1:-0}"
}

cmd_build() {
    local variant="${1:-}"
    local dockerfile="Dockerfile"
    local tag="localhost/cove"

    if [ -n "$variant" ]; then
        dockerfile="Dockerfile.${variant}"
        tag="localhost/cove-${variant}"
        if [ ! -f "${SCRIPT_DIR}/${dockerfile}" ]; then
            echo "Unknown variant: ${variant} (no ${dockerfile} found)" >&2
            exit 1
        fi
    fi

    local tz
    tz="$(timedatectl show --property=Timezone --value 2>/dev/null || echo UTC)"

    echo "Building ${tag} image..."
    podman build \
        --security-opt label=disable \
        --build-arg "TZ=${tz}" \
        --build-arg "CACHE_BUST=$(date +%s)" \
        -f "${SCRIPT_DIR}/${dockerfile}" \
        -t "${tag}" \
        "${SCRIPT_DIR}"
}

cmd_upgrade() {
    echo "Pulling latest..."
    git -C "$SCRIPT_DIR" pull --ff-only

    cmd_build

    for df in "$SCRIPT_DIR"/Dockerfile.*; do
        [ -f "$df" ] || continue
        variant="${df##*.}"
        if podman image exists "localhost/cove-${variant}"; then
            cmd_build "$variant"
        fi
    done
}

cmd_run() {
    local tool="$1"
    shift

    # Parse -e flags for extra environment variables
    local extra_env=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -e) extra_env+=(-e "$2"); shift 2 ;;
            -e*) extra_env+=(-e "${1#-e}"); shift ;;
            *) break ;;
        esac
    done

    # Next arg: if it's a directory, use as workspace
    local workspace="."
    if [ $# -gt 0 ] && [ -d "$1" ]; then
        workspace="$1"
        shift
    fi

    # Resolve workspace to absolute path
    workspace="$(cd "$workspace" && pwd)"

    # Refuse to mount home directory (SELinux won't allow relabeling it,
    # and it exposes far more than intended)
    local real_home
    real_home="$(cd "$HOME" && pwd -P)"
    if [ "$workspace" = "$HOME" ] || [ "$workspace" = "$real_home" ]; then
        echo "Error: refusing to mount home directory as workspace." >&2
        echo "Run from a project directory, or specify one: cove $tool ~/project" >&2
        exit 1
    fi

    # Build container command based on tool selection
    local CMD=()
    case "$tool" in
        claude)
            CMD=("claude" "--dangerously-skip-permissions" "$@")
            ;;
        codex)
            CMD=("codex" "--yolo" "$@")
            ;;
        kimi)
            CMD=("kimi" "--yolo" "$@")
            ;;
        shell)
            CMD=("zsh" "$@")
            ;;
        *)
            CMD=("$tool" "$@")
            ;;
    esac

    # Container name: cove-<dirname>-<pid>
    local dirname
    dirname="$(basename "$workspace")"
    local name
    name="$(echo "cove-${dirname}-$$" | sed 's/[^a-zA-Z0-9_.-]/_/g; s/^[._]*//')"

    # Ensure config directories exist on host
    mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.kimi"

    # SELinux: disable labeling for all containers (required on Bazzite where
    # RELRO protection blocks library loading in rootless containers)
    local gpu_flags=()
    if [[ "${COVE_IMAGE:-}" == gpu-* ]]; then
        gpu_flags=(--device /dev/kfd --device /dev/dri)
    fi

    # Git worktree detection: if .git is a file, find and mount original repo
    local worktree_mounts=()
    local dot_git="$workspace/.git"

    if [ -f "$dot_git" ]; then
        local gitdir_line
        gitdir_line="$(cat "$dot_git")"
        if [[ "$gitdir_line" =~ ^gitdir:\ (.+)$ ]]; then
            local gitdir_path="${BASH_REMATCH[1]}"
            [[ "$gitdir_path" != /* ]] && gitdir_path="$workspace/$gitdir_path"
            gitdir_path="$(realpath "$gitdir_path" 2>/dev/null || echo "$gitdir_path")"

            if [[ "$gitdir_path" =~ ^(.+/\.git)/worktrees/ ]]; then
                local original_repo
                original_repo="$(dirname "${BASH_REMATCH[1]}")"
                if [ "$original_repo" != "$workspace" ]; then
                    worktree_mounts=(-v "$original_repo:$original_repo")
                fi
            fi
        fi
    fi

    # Git config: include user's .gitconfig but override credential helpers
    # so git authenticates via gh inside the container (where host gh paths
    # don't exist). The empty helper = line clears inherited helpers before
    # setting the container-correct one.
    local gitconfig_mounts=()
    local gitconfig_wrapper=""
    if [ -f "$HOME/.gitconfig" ]; then
        gitconfig_wrapper="$(mktemp)"
        cat > "$gitconfig_wrapper" <<'GITCFG'
[include]
    path = /tmp/.gitconfig.host
[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
[url "https://github.com/"]
    insteadOf = git@github.com:
GITCFG
        gitconfig_mounts=(
            -v "$HOME/.gitconfig:/tmp/.gitconfig.host:ro"
            -v "$gitconfig_wrapper:/tmp/.gitconfig:ro"
            -e GIT_CONFIG_GLOBAL=/tmp/.gitconfig
        )
    fi

    # Modal config (mount if exists)
    local modal_mount=""
    [ -f "$HOME/.modal.toml" ] && modal_mount="$HOME/.modal.toml:$HOME/.modal.toml:ro"

    if ! podman image exists "$IMAGE_NAME"; then
        echo "Error: image '$IMAGE_NAME' not found." >&2
        echo "Build it first: cove build${COVE_IMAGE:+ $COVE_IMAGE}" >&2
        exit 1
    fi

    podman run --log-driver=none -it --rm \
        --security-opt label=disable \
        --user="$(id -u):$(id -g)" \
        --userns=keep-id \
        --name="$name" \
        -v "$workspace:$workspace" \
        -w "$workspace" \
        -v "$HOME/.claude:$HOME/.claude" \
        -v "$HOME/.codex:$HOME/.codex" \
        -v "$HOME/.kimi:$HOME/.kimi" \
        -v "$HOME/.config/gh:$HOME/.config/gh:ro" \
        ${modal_mount:+-v "$modal_mount"} \
        "${gitconfig_mounts[@]}" \
        -v "cove-cache:/cache" \
        "${worktree_mounts[@]}" \
        -e "HOME=$HOME" \
        -e "CARGO_HOME=/cache/cargo" \
        -e "CLAUDE_CONFIG_DIR=$HOME/.claude" \
        -e ANTHROPIC_API_KEY \
        -e CLAUDE_CODE_OAUTH_TOKEN \
        -e CODEX_API_KEY \
        -e KIMI_API_KEY \
        -e OPENAI_API_KEY \
        -e OPENROUTER_API_KEY \
        -e GOOGLE_API_KEY \
        -e MISTRAL_API_KEY \
        -e MODAL_TOKEN_ID \
        -e MODAL_TOKEN_SECRET \
        "${gpu_flags[@]}" \
        "${extra_env[@]}" \
        "$IMAGE_NAME" \
        "${CMD[@]}"

    # Clean up tempfile
    [ -n "$gitconfig_wrapper" ] && rm -f "$gitconfig_wrapper"
}

cmd_test() {
    local fail=0
    local pass=0
    local variant="${COVE_IMAGE:-}"
    local image="localhost/cove${variant:+-$variant}"
    local run="podman run --rm --security-opt label=disable --userns=keep-id"

    _pass() { pass=$((pass + 1)); printf '  \033[32m✓\033[0m %s\n' "$1"; }
    _fail() { fail=$((fail + 1)); printf '  \033[31m✗\033[0m %s\n' "$1"; }
    _check() {
        if $run "$image" sh -c "$2" >/dev/null 2>&1; then
            _pass "$1"
        else
            _fail "$1"
        fi
    }

    echo "Testing ${image} image..."
    echo ""

    # Image exists
    if podman image exists "$image"; then
        _pass "image exists"
    else
        _fail "image exists"
        echo ""
        echo "$((pass + fail)) tests, $fail failed — image not built, run: cove build${variant:+ $variant}"
        return 1
    fi

    # Container starts
    _check "container starts" "true"

    # Shell
    _check "zsh" "zsh --version"

    # Core tools
    _check "git" "git --version"
    _check "ripgrep" "rg --version"
    _check "jq" "jq --version"
    _check "fzf" "fzf --version"
    _check "delta" "delta --version"
    _check "gh" "gh --version"
    _check "vim" "vim --version"

    # Languages
    _check "node" "node --version"
    _check "python3" "python3 --version"
    _check "go" "go version"
    _check "rustc" "rustc --version"
    _check "cargo" "cargo --version"
    _check "uv" "uv --version"

    # Default image extras
    if [ -z "$variant" ]; then
        _check "java" "java --version"
        _check "dotnet" "dotnet --version"
        _check "elixir" "elixir --version"
        _check "opam" "opam --version"
    fi

    # AI coding tools
    _check "claude" "claude --version"
    _check "codex" "codex --version"
    _check "kimi" "kimi --version"
    _check "modal" "modal --version"

    # GPU variant extras
    if [ "$variant" = "gpu-amd" ]; then
        _check "ollama" "ollama --version"
        _check "rocm-smi" "rocm-smi --version"
        _check "pytorch" "python3 -c 'import torch; print(torch.__version__)'"
        _check "transformers" "python3 -c 'import transformers; print(transformers.__version__)'"
    fi

    # Mounts
    local tmpdir
    tmpdir="$(mktemp -d)"
    echo "test" > "$tmpdir/probe"
    if $run -v "$tmpdir:$tmpdir" "$image" cat "$tmpdir/probe" | grep -q test; then
        _pass "workspace mount"
    else
        _fail "workspace mount"
    fi
    rm -rf "$tmpdir"

    # Cache volume
    if $run -v cove-cache:/cache "$image" sh -c "test -d /cache && touch /cache/.probe && rm /cache/.probe"; then
        _pass "cache volume writable"
    else
        _fail "cache volume writable"
    fi

    echo ""
    echo "$((pass + fail)) tests, $fail failed"
    return $fail
}

cmd_ps() {
    podman ps --filter "name=cove-" --format "table {{.Names}}\t{{.Status}}\t{{.Created}}"
}

cmd_stop() {
    if [ -z "${1:-}" ]; then
        echo "Usage: cove stop <name>" >&2
        exit 1
    fi
    podman stop "$1"
}

cmd_exec() {
    if [ -z "${1:-}" ]; then
        echo "Usage: cove exec <name>" >&2
        exit 1
    fi
    podman exec -it "$1" zsh
}

# Reserved management commands
case "${1:-}" in
    build)      shift; cmd_build "$@" ;;
    upgrade)    cmd_upgrade ;;
    test)       cmd_test ;;
    ps)         cmd_ps ;;
    stop)       shift; cmd_stop "$@" ;;
    exec)       shift; cmd_exec "$@" ;;
    -h|--help|help) show_help ;;
    "")         show_help 1 ;;
    # Everything else: treat as a tool name → run it
    *)          cmd_run "$@" ;;
esac

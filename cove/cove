#!/bin/bash
set -e

# Resolve the directory containing this script (and the Dockerfile)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

IMAGE_NAME="cove"

show_help() {
    cat <<'EOF'
Usage: cove <tool> [-e VAR[=val]...] [path] [args...]
       cove <command> [args...]

Run AI coding tools in an isolated container.

Tools:
    cove claude                    Claude Code in current directory
    cove codex                     Codex in current directory
    cove kimi                      Kimi Code in current directory
    cove claude ~/project          Claude Code in ~/project
    cove claude --resume           Pass extra args to tool
    cove shell                     Interactive shell
    cove claude -e MY_KEY=secret   Pass extra env vars

Management:
    cove build                     Build/rebuild the container image
    cove ps                        List running coves
    cove stop <name>               Stop a running cove
    cove exec <name>               Attach to a running cove

Auto-passed env vars (if set on host):
    ANTHROPIC_API_KEY, CLAUDE_CODE_OAUTH_TOKEN, CODEX_API_KEY,
    KIMI_API_KEY, OPENAI_API_KEY, OPENROUTER_API_KEY,
    GOOGLE_API_KEY, MISTRAL_API_KEY
EOF
    exit "${1:-0}"
}

cmd_build() {
    local tz
    tz="$(timedatectl show --property=Timezone --value 2>/dev/null || echo UTC)"

    echo "Building ${IMAGE_NAME} image..."
    podman build \
        --build-arg "TZ=${tz}" \
        -t "${IMAGE_NAME}" \
        "${SCRIPT_DIR}"
}

cmd_run() {
    local tool="$1"
    shift

    # Parse -e flags for extra environment variables
    local extra_env=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -e) extra_env+=(-e "$2"); shift 2 ;;
            -e*) extra_env+=(-e "${1#-e}"); shift ;;
            *) break ;;
        esac
    done

    # Next arg: if it's a directory, use as workspace
    local workspace="."
    if [ $# -gt 0 ] && [ -d "$1" ]; then
        workspace="$1"
        shift
    fi

    # Resolve workspace to absolute path
    workspace="$(cd "$workspace" && pwd)"

    # Build container command based on tool selection
    local CMD=()
    case "$tool" in
        claude)
            CMD=("claude" "--dangerously-skip-permissions" "$@")
            ;;
        codex)
            CMD=("codex" "--yolo" "$@")
            ;;
        kimi)
            CMD=("kimi" "--yolo" "$@")
            ;;
        shell)
            CMD=("zsh" "$@")
            ;;
        *)
            CMD=("$tool" "$@")
            ;;
    esac

    # Container name: cove-<dirname>-<pid>
    local dirname
    dirname="$(basename "$workspace")"
    local name
    name="$(echo "cove-${dirname}-$$" | sed 's/[^a-zA-Z0-9_.-]/_/g; s/^[._]*//')"

    # Ensure config directories exist on host
    mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.kimi"

    # Git worktree detection: if .git is a file, find and mount original repo
    local worktree_mounts=()
    local dot_git="$workspace/.git"

    if [ -f "$dot_git" ]; then
        local gitdir_line
        gitdir_line="$(cat "$dot_git")"
        if [[ "$gitdir_line" =~ ^gitdir:\ (.+)$ ]]; then
            local gitdir_path="${BASH_REMATCH[1]}"
            [[ "$gitdir_path" != /* ]] && gitdir_path="$workspace/$gitdir_path"
            gitdir_path="$(realpath "$gitdir_path" 2>/dev/null || echo "$gitdir_path")"

            if [[ "$gitdir_path" =~ ^(.+/\.git)/worktrees/ ]]; then
                local original_repo
                original_repo="$(dirname "${BASH_REMATCH[1]}")"
                if [ "$original_repo" != "$workspace" ]; then
                    worktree_mounts=(-v "$original_repo:$original_repo:Z")
                fi
            fi
        fi
    fi

    # Git config mount (only if .gitconfig exists)
    local gitconfig_mounts=()
    if [ -f "$HOME/.gitconfig" ]; then
        gitconfig_mounts=(
            -v "$HOME/.gitconfig:/tmp/.gitconfig:ro,Z"
            -e GIT_CONFIG_GLOBAL=/tmp/.gitconfig
        )
    fi

    podman run --log-driver=none -it --rm \
        --user="$(id -u):$(id -g)" \
        --userns=keep-id \
        --name="$name" \
        -v "$workspace:$workspace:Z" \
        -w "$workspace" \
        -v "$HOME/.claude:$HOME/.claude:Z" \
        -v "$HOME/.codex:$HOME/.codex:Z" \
        -v "$HOME/.kimi:$HOME/.kimi:Z" \
        "${gitconfig_mounts[@]}" \
        -v "cove-cache:/cache" \
        "${worktree_mounts[@]}" \
        -e "CLAUDE_CONFIG_DIR=$HOME/.claude" \
        -e ANTHROPIC_API_KEY \
        -e CLAUDE_CODE_OAUTH_TOKEN \
        -e CODEX_API_KEY \
        -e KIMI_API_KEY \
        -e OPENAI_API_KEY \
        -e OPENROUTER_API_KEY \
        -e GOOGLE_API_KEY \
        -e MISTRAL_API_KEY \
        "${extra_env[@]}" \
        "$IMAGE_NAME" \
        "${CMD[@]}"
}

cmd_ps() {
    podman ps --filter "name=cove-" --format "table {{.Names}}\t{{.Status}}\t{{.Created}}"
}

cmd_stop() {
    if [ -z "${1:-}" ]; then
        echo "Usage: cove stop <name>" >&2
        exit 1
    fi
    podman stop "$1"
}

cmd_exec() {
    if [ -z "${1:-}" ]; then
        echo "Usage: cove exec <name>" >&2
        exit 1
    fi
    podman exec -it "$1" zsh
}

# Reserved management commands
case "${1:-}" in
    build)      shift; cmd_build "$@" ;;
    ps)         cmd_ps ;;
    stop)       shift; cmd_stop "$@" ;;
    exec)       shift; cmd_exec "$@" ;;
    -h|--help|help) show_help ;;
    "")         show_help 1 ;;
    # Everything else: treat as a tool name → run it
    *)          cmd_run "$@" ;;
esac
